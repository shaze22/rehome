generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String      @id @default(cuid())
  email           String      @unique
  name            String?
  avatar          String?
  icVerified      Boolean     @default(false)
  icStatus        ICStatus    @default(UNVERIFIED)
  icPhoto         String?
  rehomeScore     Int         @default(50)
  state           String?
  role            Role        @default(BUYER)
  swapScore       Float?
  successfulSwaps Int         @default(0)
  swapVerified    Boolean     @default(false)
  listings        Listing[]
  bids            Bid[]
  sentMessages    Message[]   @relation("MessageSender")
  reviews         Review[]    @relation("ReviewAuthor")
  receivedReviews Review[]    @relation("ReviewSeller")
  watchlist       Watchlist[]
  offers                  Offer[]
  swapTransactionsSeller  SwapTransaction[] @relation("SwapSeller")
  swapTransactionsBuyer   SwapTransaction[] @relation("SwapBuyer")
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
}

model Listing {
  id                 String        @id @default(cuid())
  title              String
  description        String
  category           Category
  condition          Int
  originalPrice      Float
  startingBid        Float         @default(0)
  currentBid         Float         @default(0)
  currentBidder      String?
  photos             String[]
  sellerId           String
  seller             User          @relation(fields: [sellerId], references: [id])
  state              String
  status             ListingStatus @default(ACTIVE)
  mode               ListingMode   @default(FLASH)
  endsAt             DateTime?
  firstBidAt         DateTime?
  swapWantedItem     String?
  swapWantedCategory String?
  swapOpenOffers     Boolean       @default(false)
  swapMinCashTopup   Float?
  swapAcceptCash     Boolean       @default(true)
  swapValueEstimate  Float?
  bids               Bid[]
  messages           Message[]
  review             Review?
  watchlist          Watchlist[]
  offers             Offer[]
  swapTransaction    SwapTransaction?
  aiSuggestedMin     Float?
  aiSuggestedMax     Float?
  aiReasoning        String?
  co2Saved           Float         @default(0)
  hasScratch         Boolean       @default(false)
  isFunctional       Boolean       @default(true)
  hasCompleteParts   Boolean       @default(true)
  hasOriginalBox     Boolean       @default(false)
  hasWarranty        Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([status, endsAt])
  @@index([sellerId])
  @@index([category])
  @@index([mode, status])
}

model Bid {
  id        String   @id @default(cuid())
  amount    Float
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  bidderId  String
  bidder    User     @relation(fields: [bidderId], references: [id])
  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([bidderId])
}

model Transaction {
  id                String            @id @default(cuid())
  listingId         String            @unique
  sellerId          String
  buyerId           String
  amount            Float
  platformFee       Float
  sellerPayout      Float
  stripePaymentId   String?
  status            TransactionStatus @default(PENDING)
  shippingStatus    ShippingStatus    @default(PENDING)
  trackingNumber    String?
  deliveryConfirmed Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  senderId  String
  sender    User     @relation("MessageSender", fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([listingId])
}

model Review {
  id         String   @id @default(cuid())
  listingId  String   @unique
  listing    Listing  @relation(fields: [listingId], references: [id])
  reviewerId String
  reviewer   User     @relation("ReviewAuthor", fields: [reviewerId], references: [id])
  sellerId   String
  seller     User     @relation("ReviewSeller", fields: [sellerId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@index([sellerId])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

model Offer {
  id                String      @id @default(cuid())
  listingId         String
  listing           Listing     @relation(fields: [listingId], references: [id])
  bidderId          String
  bidder            User        @relation(fields: [bidderId], references: [id])
  offerType         OfferType
  offeredItemPhotos String[]
  offeredItemDesc   String?
  offeredCashAmount Float?
  offeredItemValue  Float?
  totalOfferValue   Float?
  message           String?
  status            OfferStatus @default(PENDING)
  counterRounds     Int         @default(0)
  parentOfferId     String?
  parentOffer       Offer?          @relation("OfferCounter", fields: [parentOfferId], references: [id])
  counterOffers     Offer[]         @relation("OfferCounter")
  swapTransaction   SwapTransaction?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  expiresAt         DateTime?

  @@index([listingId])
  @@index([bidderId])
  @@index([status])
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum Category {
  FURNITURE
  ELECTRONICS
  FASHION
  BOOKS
  SPORTS
  KITCHEN
  OTHERS
}

enum ListingStatus {
  ACTIVE
  ENDED
  SOLD
  CANCELLED
}

enum ICStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum TransactionStatus {
  PENDING
  ESCROWED
  RELEASED
  REFUNDED
}

enum ShippingStatus {
  PENDING
  SHIPPED
  DELIVERED
}

model SwapTransaction {
  id                 String       @id @default(cuid())
  listingId          String       @unique
  listing            Listing      @relation(fields: [listingId], references: [id])
  acceptedOfferId    String       @unique
  acceptedOffer      Offer        @relation(fields: [acceptedOfferId], references: [id])
  sellerId           String
  seller             User         @relation("SwapSeller", fields: [sellerId], references: [id])
  buyerId            String
  buyer              User         @relation("SwapBuyer", fields: [buyerId], references: [id])
  offerType          OfferType
  escrowStatus       EscrowStatus @default(PENDING)
  sellerItemShipped  Boolean      @default(false)
  buyerItemShipped   Boolean?
  sellerItemReceived Boolean      @default(false)
  buyerItemReceived  Boolean      @default(false)
  sellerPhotos       String[]
  buyerPhotos        String[]
  sellerTracking     String?
  buyerTracking      String?
  sellerCourier      String?
  buyerCourier       String?
  disputeReason      String?
  disputeEvidence    String[]
  resolvedAt         DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([sellerId])
  @@index([buyerId])
}

enum EscrowStatus {
  PENDING
  BOTH_SHIPPED
  COMPLETED
  DISPUTED
}

enum ListingMode {
  FLASH
  SWAP
}

enum OfferType {
  CASH
  SWAP
  HYBRID
}

enum OfferStatus {
  PENDING
  COUNTERED
  ACCEPTED
  REJECTED
  EXPIRED
}
