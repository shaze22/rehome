generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String      @id @default(cuid())
  email           String      @unique
  name            String?
  avatar          String?
  icVerified      Boolean     @default(false)
  icStatus        ICStatus    @default(UNVERIFIED)
  icPhoto         String?
  rehomeScore     Int         @default(50)
  phone           String?
  state           String?
  role            Role        @default(BUYER)
  swapScore       Float?
  successfulSwaps Int         @default(0)
  swapVerified    Boolean     @default(false)
  referralCode    String?     @unique
  creditBalance   Float       @default(0)
  referrals         Referral[]         @relation("ReferrerReferrals")
  referredBy        Referral?          @relation("ReferredUser")
  pushSubscriptions PushSubscription[]
  listings          Listing[]
  bids            Bid[]
  sentMessages    Message[]   @relation("MessageSender")
  reviews         Review[]    @relation("ReviewAuthor")
  receivedReviews Review[]    @relation("ReviewSeller")
  watchlist       Watchlist[]
  offers                  Offer[]
  swapTransactionsSeller  SwapTransaction[] @relation("SwapSeller")
  swapTransactionsBuyer   SwapTransaction[] @relation("SwapBuyer")
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
}

model Listing {
  id                 String        @id @default(cuid())
  title              String
  description        String
  category           Category
  condition          Int
  originalPrice      Float
  startingBid        Float         @default(0)
  currentBid         Float         @default(0)
  currentBidder      String?
  photos             String[]
  sellerId           String
  seller             User          @relation(fields: [sellerId], references: [id])
  state              String
  status             ListingStatus @default(ACTIVE)
  mode               ListingMode   @default(FLASH)
  endsAt             DateTime?
  firstBidAt         DateTime?
  swapWantedItem     String?
  swapWantedCategory String?
  swapOpenOffers     Boolean       @default(false)
  swapMinCashTopup   Float?
  swapAcceptCash     Boolean       @default(true)
  swapValueEstimate  Float?
  bids               Bid[]
  messages           Message[]
  reviews            Review[]
  watchlist          Watchlist[]
  offers             Offer[]
  swapTransaction    SwapTransaction?
  weightKg           Float         @default(1)
  aiSuggestedMin     Float?
  aiSuggestedMax     Float?
  aiReasoning        String?
  viewCount          Int           @default(0)
  isFeatured         Boolean       @default(false)
  featuredAt         DateTime?
  featuredUntil      DateTime?
  co2Saved           Float         @default(0)
  hasScratch         Boolean       @default(false)
  isFunctional       Boolean       @default(true)
  hasCompleteParts   Boolean       @default(true)
  hasOriginalBox     Boolean       @default(false)
  hasWarranty        Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([status, endsAt])
  @@index([sellerId])
  @@index([category])
  @@index([mode, status])
}

model Bid {
  id        String   @id @default(cuid())
  amount    Float
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  bidderId  String
  bidder    User     @relation(fields: [bidderId], references: [id])
  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([bidderId])
  @@index([listingId, createdAt])
}

model Transaction {
  id                    String            @id @default(cuid())
  listingId             String            @unique
  sellerId              String
  buyerId               String
  amount                Float
  platformFee           Float
  sellerPayout          Float
  stripePaymentId       String?
  status                TransactionStatus @default(PENDING)
  shippingStatus        ShippingStatus    @default(PENDING)
  trackingNumber        String?
  deliveryConfirmed     Boolean           @default(false)
  pickupMethod          String?
  sellerPickupConfirmed Boolean           @default(false)
  // Delivery via platform
  deliveryFee           Float?            // charged to buyer (base + 30% markup)
  deliveryBase          Float?            // cost platform pays courier
  deliveryMarkup        Float?            // platform's 30% cut
  courierName           String?
  courierService        String?
  courierServiceId      String?           // EasyParcel service_id for booking
  easyparcelOrderId     String?
  buyerPostcode         String?
  buyerPhone            String?
  buyerAddress          String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  senderId  String
  sender    User     @relation("MessageSender", fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([listingId])
}

model Review {
  id         String   @id @default(cuid())
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id])
  reviewerId String
  reviewer   User     @relation("ReviewAuthor", fields: [reviewerId], references: [id])
  sellerId   String
  seller     User     @relation("ReviewSeller", fields: [sellerId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([listingId, reviewerId])
  @@index([sellerId])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

model Offer {
  id                String      @id @default(cuid())
  listingId         String
  listing           Listing     @relation(fields: [listingId], references: [id])
  bidderId          String
  bidder            User        @relation(fields: [bidderId], references: [id])
  offerType         OfferType
  offeredItemPhotos String[]
  offeredItemDesc   String?
  offeredCashAmount Float?
  offeredItemValue  Float?
  totalOfferValue   Float?
  message           String?
  status            OfferStatus @default(PENDING)
  counterRounds     Int         @default(0)
  parentOfferId     String?
  parentOffer       Offer?          @relation("OfferCounter", fields: [parentOfferId], references: [id])
  counterOffers     Offer[]         @relation("OfferCounter")
  swapTransaction   SwapTransaction?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  expiresAt         DateTime?

  @@index([listingId])
  @@index([bidderId])
  @@index([status])
  @@index([expiresAt])
  @@index([listingId, status])
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum Category {
  FURNITURE
  ELECTRONICS
  FASHION
  BOOKS
  SPORTS
  KITCHEN
  OTHERS
}

enum ListingStatus {
  ACTIVE
  ENDED
  SOLD
  CANCELLED
}

enum ICStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum TransactionStatus {
  PENDING
  ESCROWED
  RELEASED
  REFUNDED
}

enum ShippingStatus {
  PENDING
  SHIPPED
  DELIVERED
}

model SwapTransaction {
  id                 String       @id @default(cuid())
  listingId          String       @unique
  listing            Listing      @relation(fields: [listingId], references: [id])
  acceptedOfferId    String       @unique
  acceptedOffer      Offer        @relation(fields: [acceptedOfferId], references: [id])
  sellerId           String
  seller             User         @relation("SwapSeller", fields: [sellerId], references: [id])
  buyerId            String
  buyer              User         @relation("SwapBuyer", fields: [buyerId], references: [id])
  offerType          OfferType
  escrowStatus       EscrowStatus @default(PENDING)
  sellerItemShipped  Boolean      @default(false)
  buyerItemShipped   Boolean?
  sellerItemReceived Boolean      @default(false)
  buyerItemReceived  Boolean      @default(false)
  sellerPhotos       String[]
  buyerPhotos        String[]
  sellerTracking     String?
  buyerTracking      String?
  sellerCourier      String?
  buyerCourier       String?
  disputeReason      String?
  disputeEvidence    String[]
  resolvedAt         DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([sellerId])
  @@index([buyerId])
  @@index([escrowStatus])
  @@index([createdAt])
}

enum EscrowStatus {
  PENDING
  BOTH_SHIPPED
  COMPLETED
  DISPUTED
}

enum ListingMode {
  FLASH
  SWAP
}

enum OfferType {
  CASH
  SWAP
  HYBRID
}

enum OfferStatus {
  PENDING
  COUNTERED
  ACCEPTED
  REJECTED
  EXPIRED
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referrer    User     @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referredId  String   @unique
  referred    User     @relation("ReferredUser", fields: [referredId], references: [id])
  rewardGiven Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([referrerId])
}
